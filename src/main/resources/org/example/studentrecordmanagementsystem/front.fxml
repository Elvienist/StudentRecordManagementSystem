<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.studentrecordmanagementsystem.Controller">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <children>
      <HBox alignment="TOP_CENTER" spacing="40.0">
         <children>
            <VBox>
               <children>
                  <Label text="Name" />
                  <TextField fx:id="txtName" />
               </children>
            </VBox>
            <VBox layoutX="10.0" layoutY="10.0">
               <children>
                  <Label text="Course" />
                  <TextField fx:id="txtCourse" />
               </children>
            </VBox>
            <VBox layoutX="10.0" layoutY="10.0">
               <children>
                  <Label text="Year" />
                  <ChoiceBox fx:id="cbYear" prefWidth="150.0" />
               </children>
            </VBox>
         </children>
      </HBox>
      <HBox alignment="TOP_CENTER" layoutX="30.0" layoutY="30.0" spacing="40.0">
         <children>
            <Button mnemonicParsing="false" onAction="#addStudent" text="Add" />
            <Button mnemonicParsing="false" onAction="#updateStudent" text="Update" />
            <Button mnemonicParsing="false" onAction="#deleteStudent" text="Delete" />
            <Button mnemonicParsing="false" onAction="#clearFields" text="Clear" />
         </children>
      </HBox>
      <TableView fx:id="table" prefHeight="200.0" prefWidth="200.0">
        <columns>
          <TableColumn fx:id="colId" prefWidth="75.0" text="ID" />
          <TableColumn fx:id="colName" prefWidth="75.0" text="Name" />
            <TableColumn fx:id="colCourse" prefWidth="75.0" text="Course" />
            <TableColumn fx:id="colYear" prefWidth="75.0" text="Year Level" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </children>
</VBox>
