<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.studentrecordmanagementsystem.LoginController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>
    <children>
        <Label text="Student Record System"/>
        <VBox spacing="5.0">
            <Label text="Username"/>
            <TextField fx:id="txtUsername"/>
        </VBox>
        <VBox spacing="5.0">
            <Label text="Password"/>
            <PasswordField fx:id="txtPassword"/>
        </VBox>
        <HBox alignment="CENTER" spacing="40.0">
            <Button mnemonicParsing="false" onAction="#login" text="Login"/>
        </HBox>
        <Label fx:id="lblError" style="-fx-text-fill: red;"/>
    </children>
</VBox>